{
    HAL_UART_Transmit(&hlpuart1, (uint8_t*)msg, strlen(msg), HAL_MAX_DELAY);
}

static uint8_t PB0_WasPressed(void)
{
    if ((GPIOB->IDR & GPIO_PIN_0) == 0)
    {
        HAL_Delay(50);
        if ((GPIOB->IDR & GPIO_PIN_0) == 0)
        {
            while ((GPIOB->IDR & GPIO_PIN_0) == 0) HAL_Delay(10);
            return 1;
        }
    }
    return 0;
}

/* Returns 1 if PB0 is HIGH (not pressed), 0 if LOW (pressed) */
static uint8_t PB0_IsHigh(void)
{
    return (GPIOB->IDR & GPIO_PIN_0) ? 1 : 0;
}

/* B1 = PC13, active low (Nucleo USER button) */
static uint8_t B1_WasPressed(void)
{
    if ((GPIOC->IDR & GPIO_PIN_13) == 0)
    {
        HAL_Delay(50);
        if ((GPIOC->IDR & GPIO_PIN_13) == 0)
        {
            while ((GPIOC->IDR & GPIO_PIN_13) == 0) HAL_Delay(10);
            return 1;
        }
    }
    return 0;
}

/* ── Splash + Menu ────────────────────────────────────────────────
 * Shows title screen then lets user pick difficulty.
 * B1 = cycle, PB0 = confirm
 * Returns selected difficulty (or HARD for ADAPTIVE which sets
 * adaptive_mode flag).
 * ─────────────────────────────────────────────────────────────── */
static void ShowSplash(void)
{
    ILI9341_FillScreen(ILI9341_BLACK);

    /* Title - big and pink/magenta */
    ILI9341_DrawString(10,  40, "MOVES",  ILI9341_MAGENTA, ILI9341_BLACK, 4);
    ILI9341_DrawString(10,  90, "LIKE",   ILI9341_MAGENTA, ILI9341_BLACK, 4);
    ILI9341_DrawString(10, 140, "JAGGER", ILI9341_MAGENTA, ILI9341_BLACK, 4);

    /* Subtitle */
    ILI9341_DrawString(30, 210, "EE329 PROJECT", ILI9341_WHITE, ILI9341_BLACK, 1);
    ILI9341_DrawString(20, 225, "BY JAG TEAM :)", ILI9341_CYAN,  ILI9341_BLACK, 1);

    HAL_Delay(2500);
}

static Difficulty ShowMenu(void)
{
    /* Wait for any button noise to settle */
    HAL_Delay(500);

    const char *options[] = { "EASY", "MEDIUM", "HARD", "ADAPTIVE" };
    const uint16_t colors[] = { ILI9341_GREEN, ILI9341_YELLOW, ILI9341_RED, ILI9341_CYAN };
    uint8_t selected = 2; /* default HARD */

    while (1)
    {
        ILI9341_FillScreen(ILI9341_BLACK);

        /* Header */
        ILI9341_DrawString(20, 10, "SELECT MODE", ILI9341_WHITE, ILI9341_BLACK, 2);
        ILI9341_DrawString(5, 30, "B1=CYCLE  PB0=START", ILI9341_WHITE, ILI9341_BLACK, 1);

        /* Draw all options */
        for (uint8_t j = 0; j < 4; j++)
        {
            uint16_t y = 70 + j * 55;
            if (j == selected)
            {
                /* Highlight selected */
                ILI9341_FillRect(0, y - 5, 240, 45, colors[j]);
                ILI9341_DrawString(10, y + 8, options[j], ILI9341_BLACK, colors[j], 2);
                ILI9341_DrawString(190, y + 8, "<", ILI9341_BLACK, colors[j], 2);
            }
            else
            {
                ILI9341_DrawString(10, y + 8, options[j], colors[j], ILI9341_BLACK, 2);
            }
        }

        /* Wait for input:
         * B1 = cycle through options
         * PB0 = start game with selected mode (original start behavior) */
        while (1)
        {
            if (B1_WasPressed())
            {
                selected = (selected + 1) % 4;
                break; /* redraw menu */
            }
            /* PB0 - same check as original "press to start" */
            if (!PB0_IsHigh())
            {
                HAL_Delay(50);
                if (!PB0_IsHigh())
                {
                    while (!PB0_IsHigh()) HAL_Delay(10);
                    uart_print("PB0 - GAME START\r\n");
                    ILI9341_FillScreen(ILI9341_BLACK);
                    if (selected == 3) { adaptive_mode = 1; return HARD; }
                    else               { adaptive_mode = 0; return (Difficulty)selected; }
                }
            }
            HAL_Delay(10);
        }
    }
}

void DrawArrow(Arrow arrow)
{
    uint32_t t0 = HAL_GetTick();
    switch (arrow)
    {
        case ARROW_UP:    ILI9341_DrawUpArrow(ILI9341_RED);      break;
        case ARROW_DOWN:  ILI9341_DrawDownArrow(ILI9341_GREEN);  break;
        case ARROW_LEFT:  ILI9341_DrawLeftArrow(ILI9341_BLUE);   break;
        case ARROW_RIGHT: ILI9341_DrawRightArrow(ILI9341_YELLOW);break;
        default: break;
    }
    uint32_t draw_ms = HAL_GetTick() - t0;
    uint32_t fps = (draw_ms > 0) ? (1000 / draw_ms) : 999;
    char fps_buf[48];
    sprintf(fps_buf, "DRAW=%lums FPS=%lu\r\n", draw_ms, fps);
    uart_print(fps_buf);
}

