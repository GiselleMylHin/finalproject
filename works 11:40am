/* ═══════════════════════════════════════════════════════════════════
 * ARROW / FSR
 * ═══════════════════════════════════════════════════════════════════ */
typedef enum { ARROW_UP=0, ARROW_DOWN=1, ARROW_LEFT=2, ARROW_RIGHT=3, ARROW_NONE=99 } Arrow;

static Arrow FSR_GetPressed(void)
{
    if (FSR_read(FSR_UP)    > FSR_THRESHOLD) return ARROW_UP;
    if (FSR_read(FSR_DOWN)  > FSR_THRESHOLD) return ARROW_DOWN;
    if (FSR_read(FSR_LEFT)  > FSR_THRESHOLD) return ARROW_LEFT;
    if (FSR_read(FSR_RIGHT) > FSR_THRESHOLD) return ARROW_RIGHT;
    return ARROW_NONE;
}

static void FSR_WaitRelease(void)
{
    while (FSR_read(FSR_UP)    > FSR_THRESHOLD ||
           FSR_read(FSR_DOWN)  > FSR_THRESHOLD ||
           FSR_read(FSR_LEFT)  > FSR_THRESHOLD ||
           FSR_read(FSR_RIGHT) > FSR_THRESHOLD)
    { HAL_Delay(10); }
}

/* ═══════════════════════════════════════════════════════════════════
 * DISPLAY
 * ═══════════════════════════════════════════════════════════════════ */
static void DrawArrow(Arrow arrow)
{
    switch (arrow)
    {
        case ARROW_UP:    ILI9341_DrawUpArrow(ILI9341_RED);      break;
        case ARROW_DOWN:  ILI9341_DrawDownArrow(ILI9341_GREEN);  break;
        case ARROW_LEFT:  ILI9341_DrawLeftArrow(ILI9341_BLUE);   break;
        case ARROW_RIGHT: ILI9341_DrawRightArrow(ILI9341_YELLOW);break;
        default: break;
    }
}

/* ═══════════════════════════════════════════════════════════════════
 * UART / BUTTON
 * ═══════════════════════════════════════════════════════════════════ */
void uart_print(char *msg)
{
    HAL_UART_Transmit(&hlpuart1, (uint8_t*)msg, strlen(msg), HAL_MAX_DELAY);
}

static uint8_t PB0_WasPressed(void)
{
    if ((GPIOB->IDR & GPIO_PIN_0) == 0)
    {
        HAL_Delay(50);
        if ((GPIOB->IDR & GPIO_PIN_0) == 0)
        {
            while ((GPIOB->IDR & GPIO_PIN_0) == 0) HAL_Delay(10);
            return 1;
        }
    }
    return 0;
}

/* ═══════════════════════════════════════════════════════════════════
 * MAIN
 * ═══════════════════════════════════════════════════════════════════ */
int main(void)
{
    HAL_Init();
    SystemClock_Config();
    GPIO_Config();
    SPI1_Config();
    LPUART1_Config();
    USART2_Config();

    ILI9341_Init();
    ILI9341_FillScreen(ILI9341_BLACK);
    FSR_init();
    DFPlayer_Init(&huart2, &hlpuart1);
    srand(HAL_GetTick());

    /* ── Game variables ── */
    GameState   state       = STATE_IDLE;
    uint8_t     song_idx    = 0;
    uint8_t     note_idx    = 0;
    const Song *song        = NULL;
    const Note *chart       = NULL;
    Arrow       target      = ARROW_NONE;
    uint32_t    song_start  = 0;
    uint32_t    song_stop   = 0;
    uint32_t    note_time   = 0;
    uint32_t    win_start   = 0;
    uint32_t    judge_start = 0;
    uint32_t    pause_start = 0;
    char        buf[80];

    uart_print("\r\n=== MOVE LIKE JAGGER ===\r\n");
    uart_print("Press PB0 to start!\r\n");

    while (1)
    {
        switch (state)
        {
            /* ─────────────────────────────────────────────────────
             * IDLE: wait for PB0 to start the song
             * ───────────────────────────────────────────────────── */
            case STATE_IDLE:
                if (PB0_WasPressed())
                {
                    HAL_Delay(300);
                    song       = &songs[song_idx];
                    chart      = (difficulty == EASY)   ? song->easy :
                                 (difficulty == MEDIUM) ? song->medium : song->hard;
                    note_idx   = 0;
                    song_start = HAL_GetTick();
                    song_stop  = song_start + song->stop_ms;

                    sprintf(buf, "SONG: %s | DIFF: %s\r\n", song->name, diff_names[difficulty]);
                    uart_print(buf);

                    DFPlayer_Play(song->filename);
                    state = STATE_WAIT_NOTE;
                }
                break;

            /* ─────────────────────────────────────────────────────
             * WAIT_NOTE: spin until it's time to show the next arrow
             * ───────────────────────────────────────────────────── */
            case STATE_WAIT_NOTE:
                /* Song time limit hit */
                if (HAL_GetTick() >= song_stop)
                {
                    DFPlayer_Stop();
                    state = STATE_SONG_DONE;
                    break;
                }

                /* All notes done */
                if (note_idx >= song->count)
                {
                    DFPlayer_Stop();
                    state = STATE_SONG_DONE;
                    break;
                }

                /* PB0 = pause */
                if (PB0_WasPressed())
                {
                    DFPlayer_Pause();
                    pause_start = HAL_GetTick();
                    uart_print("PAUSED\r\n");
                    state = STATE_PAUSED;
                    break;
                }

                /* Is it time for this note yet? */
                note_time = song_start + chart[note_idx].time_ms;
                if (HAL_GetTick() >= note_time)
                {
                    target    = (Arrow)chart[note_idx].direction;
                    win_start = HAL_GetTick();
                    DrawArrow(target);
                    sprintf(buf, "SCORE=%lu COMBO=%lu DIFF=%s\r\n",
                            score, combo, diff_names[difficulty]);
                    uart_print(buf);
                    state = STATE_WAIT_INPUT;
                }
                break;

            /* ─────────────────────────────────────────────────────
             * WAIT_INPUT: arrow is on screen, waiting for FSR press
             * ───────────────────────────────────────────────────── */
            case STATE_WAIT_INPUT:
                /* Song time limit hit */
                if (HAL_GetTick() >= song_stop)
                {
                    DFPlayer_Stop();
                    state = STATE_SONG_DONE;
                    break;
                }

                /* PB0 = pause */
                if (PB0_WasPressed())
                {
                    DFPlayer_Pause();
                    pause_start = HAL_GetTick();
                    uart_print("PAUSED\r\n");
                    state = STATE_PAUSED;
                    break;
                }

                {
                    Arrow pressed = FSR_GetPressed();

                    if (pressed != ARROW_NONE)
                    {
                        /* FSR pressed - judge it */
                        if (pressed == target)
                        {
                            uart_print("HIT!\r\n");
                            ILI9341_FillScreen(ILI9341_GREEN);
                            Score_RecordHit(1);
                        }
                        else
                        {
                            uart_print("WRONG\r\n");
                            ILI9341_FillScreen(ILI9341_RED);
                            Score_RecordHit(0);
                        }
                        FSR_WaitRelease();
                        note_idx++;
                        if (note_idx % 10 == 0) Score_UpdateDifficulty();
                        judge_start = HAL_GetTick();
                        state = STATE_JUDGING;
                    }
                    else if ((HAL_GetTick() - win_start) >= diff_window[difficulty])
                    {
                        /* Window expired - miss */
                        uart_print("MISS\r\n");
                        Score_RecordHit(0);
                        ILI9341_FillScreen(ILI9341_RED);
                        note_idx++;
                        if (note_idx % 10 == 0) Score_UpdateDifficulty();
                        judge_start = HAL_GetTick();
                        state = STATE_JUDGING;
                    }
                }
                break;

            /* ─────────────────────────────────────────────────────
             * JUDGING: show green/red for 300ms then go to next note
             * ───────────────────────────────────────────────────── */
            case STATE_JUDGING:
                if ((HAL_GetTick() - judge_start) >= 300)
                {
                    ILI9341_FillScreen(ILI9341_BLACK);
                    state = STATE_WAIT_NOTE;
                }
                break;

            /* ─────────────────────────────────────────────────────
             * PAUSED: waiting for PB0 to resume
             * ───────────────────────────────────────────────────── */
            case STATE_PAUSED:
                if (PB0_WasPressed())
                {
                    uint32_t pause_dur = HAL_GetTick() - pause_start;
                    song_start += pause_dur;
                    song_stop  += pause_dur;
                    note_time  += pause_dur;
                    win_start  += pause_dur;
                    DFPlayer_Resume();
                    uart_print("RESUMED\r\n");
                    HAL_Delay(300);
                    /* Return to where we were */
                    state = STATE_WAIT_INPUT;
                }
                break;

            /* ─────────────────────────────────────────────────────
             * SONG_DONE: show score, wait for PB0, advance song
             * ───────────────────────────────────────────────────── */
            case STATE_SONG_DONE:
                sprintf(buf, "SONG DONE! SCORE=%lu\r\n", score);
                uart_print(buf);
                ILI9341_FillScreen(ILI9341_BLACK);
                HAL_Delay(2000);

                uart_print("Press PB0 for next song!\r\n");
                while (!PB0_WasPressed()) HAL_Delay(10);
                HAL_Delay(300);

                song_idx = (song_idx + 1) % 2;
                Score_Reset();
                state = STATE_IDLE;
                break;
        }

        HAL_Delay(5);
    }
}

/* ═══════════════════════════════════════════════════════════════════
 * PERIPHERAL CONFIG
 * ═══════════════════════════════════════════════════════════════════ */
static void GPIO_Config(void)
{
    RCC->AHB2ENR |= RCC_AHB2ENR_GPIOAEN | RCC_AHB2ENR_GPIOCEN |
                    RCC_AHB2ENR_GPIOGEN  | RCC_AHB2ENR_GPIOBEN;
    HAL_PWREx_EnableVddIO2();

    GPIOA->MODER &= ~((3U << (2*2)) | (3U << (3*2)));
    GPIOA->MODER |=  ((2U << (2*2)) | (2U << (3*2)));
    GPIOA->OTYPER  &= ~(GPIO_PIN_2 | GPIO_PIN_3);
    GPIOA->OSPEEDR |=  ((3U << (2*2)) | (3U << (3*2)));
    GPIOA->PUPDR   &= ~((3U << (2*2)) | (3U << (3*2)));
    GPIOA->AFR[0]  &= ~((0xFU << GPIO_AFRL_AFSEL2_Pos) | (0xFU << GPIO_AFRL_AFSEL3_Pos));
    GPIOA->AFR[0]  |=  ((7U << GPIO_AFRL_AFSEL2_Pos) | (7U << GPIO_AFRL_AFSEL3_Pos));

    GPIOB->MODER &= ~(3U << (0*2));
    GPIOB->PUPDR &= ~(3U << (0*2));
    GPIOB->PUPDR |=  (1U << (0*2));

    GPIOA->MODER &= ~((3U << (5*2)) | (3U << (7*2)));
    GPIOA->MODER |=  ((2U << (5*2)) | (2U << (7*2)));
    GPIOA->OTYPER  &= ~(GPIO_PIN_5 | GPIO_PIN_7);
    GPIOA->OSPEEDR |=  ((3U << (5*2)) | (3U << (7*2)));
    GPIOA->PUPDR   &= ~((3U << (5*2)) | (3U << (7*2)));
    GPIOA->AFR[0]  &= ~((0xFU << GPIO_AFRL_AFSEL5_Pos) | (0xFU << GPIO_AFRL_AFSEL7_Pos));
    GPIOA->AFR[0]  |=  ((5U << GPIO_AFRL_AFSEL5_Pos) | (5U << GPIO_AFRL_AFSEL7_Pos));

    GPIOC->MODER &= ~((3U << (3*2)) | (3U << (4*2)) | (3U << (8*2)));
    GPIOC->MODER |=  ((1U << (3*2)) | (1U << (4*2)) | (1U << (8*2)));
    GPIOC->OTYPER  &= ~(GPIO_PIN_3 | GPIO_PIN_4 | GPIO_PIN_8);
    GPIOC->OSPEEDR |=  ((3U << (3*2)) | (3U << (4*2)) | (3U << (8*2)));
    GPIOC->PUPDR   &= ~((3U << (3*2)) | (3U << (4*2)) | (3U << (8*2)));
    GPIOC->BSRR = GPIO_PIN_4;
    GPIOC->BSRR = GPIO_PIN_8;
    GPIOC->BRR  = GPIO_PIN_3;
}

static void SPI1_Config(void)
{
    RCC->APB2ENR |= RCC_APB2ENR_SPI1EN;
    SPI1->CR1 &= ~SPI_CR1_SPE;
    SPI1->CR1 = 0; SPI1->CR2 = 0;
    SPI1->CR1 |= SPI_CR1_MSTR | SPI_CR1_SSM | SPI_CR1_SSI;
    SPI1->CR1 |= SPI_CR1_BIDIMODE | SPI_CR1_BIDIOE;
    SPI1->CR1 &= ~(SPI_CR1_CPOL | SPI_CR1_CPHA | SPI_CR1_LSBFIRST | SPI_CR1_BR);
    SPI1->CR2 &= ~SPI_CR2_DS;
    SPI1->CR2 |= (7U << SPI_CR2_DS_Pos) | SPI_CR2_FRXTH;
    SPI1->CR1 |= SPI_CR1_SPE;
}

static void LPUART1_Config(void)
{
    RCC->APB1ENR2 |= RCC_APB1ENR2_LPUART1EN;
    GPIOG->MODER &= ~((3U << (7*2)) | (3U << (8*2)));
    GPIOG->MODER |=  ((2U << (7*2)) | (2U << (8*2)));
    GPIOG->AFR[0] &= ~(0xFU << GPIO_AFRL_AFSEL7_Pos);
    GPIOG->AFR[0] |=  (8U   << GPIO_AFRL_AFSEL7_Pos);
    GPIOG->AFR[1] &= ~(0xFU << GPIO_AFRH_AFSEL8_Pos);
    GPIOG->AFR[1] |=  (8U   << GPIO_AFRH_AFSEL8_Pos);
    hlpuart1.Instance = LPUART1;
    hlpuart1.Init.BaudRate = 115200;
    hlpuart1.Init.WordLength = UART_WORDLENGTH_8B;
    hlpuart1.Init.StopBits = UART_STOPBITS_1;
    hlpuart1.Init.Parity = UART_PARITY_NONE;
    hlpuart1.Init.Mode = UART_MODE_TX_RX;
    hlpuart1.Init.HwFlowCtl = UART_HWCONTROL_NONE;
    hlpuart1.Init.OneBitSampling = UART_ONE_BIT_SAMPLE_DISABLE;
    hlpuart1.AdvancedInit.AdvFeatureInit = UART_ADVFEATURE_NO_INIT;
    HAL_UART_Init(&hlpuart1);
}

